# MySafePass Backend Configuration
# Copy this file to .env and configure your environment

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database Configuration
DATABASE_PATH=data/mysafepass.db
DATABASE_ENCRYPTION_KEY=your-database-encryption-key-32-chars

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# Security Configuration
RATE_LIMIT_DEFAULT=100 per hour
RATE_LIMIT_AUTH=5 per minute

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=5000